{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "yepyeniwatch",
  "main": "worker/src/index.js",
  "compatibility_date": "2025-12-16",
  "assets": {
    "directory": "./frend",
    "binding": "ASSETS"
  },
  "vars": {
    "ENVIRONMENT": "production"
  },
  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "16bdfdf826f647288b6e7c3d21247b0d"
    }
  ]
}

